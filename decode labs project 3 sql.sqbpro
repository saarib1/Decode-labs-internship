FROM &quot;Dataset for Data Analytics project 3&quot;;
SELECT COUNT(*)
FROM &quot;Dataset for Data Analytics project 3&quot;;
SELECT Product, TotalPrice
FROM &quot;Dataset for Data Analytics project 3&quot;;
SELECT *
FROM &quot;Dataset for Data Analytics project 3&quot;
WHERE OrderStatus = 'Delivered';
SELECT *
FROM &quot;Dataset for Data Analytics project 3&quot;
WHERE Product = 'Laptop';
SELECT Product,
       COUNT(*) AS NumberOfOrders
FROM &quot;Dataset for Data Analytics project 3&quot;
GROUP BY Product;
SELECT Product,
       COUNT(*) AS DeliveredOrders
FROM &quot;Dataset for Data Analytics project 3&quot;
WHERE OrderStatus = 'Delivered'
GROUP BY Product
ORDER BY DeliveredOrders DESC;</sql><current_tab id="0"/></tab_sql></sqlb_project>
